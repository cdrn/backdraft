{
  "name": "backdraft",
  "version": "0.1.0",
  "description": "Real-time contract deployment scanner and MEV searcher",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "delta": "tsx src/delta/main.ts",
    "delta:backfill": "tsx src/delta/backfill.ts",
    "start:delta": "node dist/delta/main.js",
    "funding": "tsx src/funding/main.ts",
    "start:funding": "node dist/funding/main.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
